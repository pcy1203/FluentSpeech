<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── 배경 이미지 ── -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── dim 오버레이 ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── 스크롤 영역 ── -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <!-- 타이틀 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Session Report"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05" />

            <View
                android:layout_width="48dp"
                android:layout_height="2dp"
                android:background="#AAFFFFFF"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp" />

            <!-- ── 요약 카드 ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <!-- 세션 시간 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0m 0s"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duration"
                            android:textSize="11sp"
                            android:textColor="#AAFFFFFF"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- 평균 긴장도 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_avg_tension"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#AAFFCC" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avg Tension"
                            android:textSize="11sp"
                            android:textColor="#AAFFFFFF"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- 총 이벤트 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_total_events"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#FFAA88" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Events"
                            android:textSize="11sp"
                            android:textColor="#AAFFFFFF"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Tension 그래프 카드 ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOICE TENSION OVER TIME"
                        android:textSize="11sp"
                        android:textColor="#AAFFFFFF"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <com.chanyoungpark.fluentspeech.TensionGraphView
                        android:id="@+id/tension_graph"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_marginTop="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Disfluency 빈도 카드 ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISFLUENCY BREAKDOWN"
                        android:textSize="11sp"
                        android:textColor="#AAFFFFFF"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <!-- 각 유형 행 -->
                    <LinearLayout android:id="@+id/layout_prolongation"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginTop="14dp">
                        <TextView android:layout_width="130dp" android:layout_height="wrap_content"
                            android:text="Prolongation" android:textColor="#CCFFFFFF" android:textSize="13sp"/>
                        <ProgressBar android:id="@+id/bar_prolongation"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp" android:layout_height="8dp"
                            android:layout_weight="1" android:max="100"
                            android:progressDrawable="@drawable/progress_voice"
                            android:background="@drawable/progress_bg"/>
                        <TextView android:id="@+id/tv_prolongation"
                            android:layout_width="28dp" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#CCFFFFFF" android:textSize="12sp"
                            android:gravity="end" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/layout_block"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginTop="10dp">
                        <TextView android:layout_width="130dp" android:layout_height="wrap_content"
                            android:text="Block" android:textColor="#CCFFFFFF" android:textSize="13sp"/>
                        <ProgressBar android:id="@+id/bar_block"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp" android:layout_height="8dp"
                            android:layout_weight="1" android:max="100"
                            android:progressDrawable="@drawable/progress_face"
                            android:background="@drawable/progress_bg"/>
                        <TextView android:id="@+id/tv_block"
                            android:layout_width="28dp" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#CCFFFFFF" android:textSize="12sp"
                            android:gravity="end" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/layout_sound_rep"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginTop="10dp">
                        <TextView android:layout_width="130dp" android:layout_height="wrap_content"
                            android:text="Sound Rep." android:textColor="#CCFFFFFF" android:textSize="13sp"/>
                        <ProgressBar android:id="@+id/bar_sound_rep"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp" android:layout_height="8dp"
                            android:layout_weight="1" android:max="100"
                            android:progressDrawable="@drawable/progress_voice"
                            android:background="@drawable/progress_bg"/>
                        <TextView android:id="@+id/tv_sound_rep"
                            android:layout_width="28dp" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#CCFFFFFF" android:textSize="12sp"
                            android:gravity="end" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/layout_word_rep"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginTop="10dp">
                        <TextView android:layout_width="130dp" android:layout_height="wrap_content"
                            android:text="Word Rep." android:textColor="#CCFFFFFF" android:textSize="13sp"/>
                        <ProgressBar android:id="@+id/bar_word_rep"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp" android:layout_height="8dp"
                            android:layout_weight="1" android:max="100"
                            android:progressDrawable="@drawable/progress_face"
                            android:background="@drawable/progress_bg"/>
                        <TextView android:id="@+id/tv_word_rep"
                            android:layout_width="28dp" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#CCFFFFFF" android:textSize="12sp"
                            android:gravity="end" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/layout_interjection"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginTop="10dp">
                        <TextView android:layout_width="130dp" android:layout_height="wrap_content"
                            android:text="Interjection" android:textColor="#CCFFFFFF" android:textSize="13sp"/>
                        <ProgressBar android:id="@+id/bar_interjection"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp" android:layout_height="8dp"
                            android:layout_weight="1" android:max="100"
                            android:progressDrawable="@drawable/progress_voice"
                            android:background="@drawable/progress_bg"/>
                        <TextView android:id="@+id/tv_interjection"
                            android:layout_width="28dp" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#CCFFFFFF" android:textSize="12sp"
                            android:gravity="end" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── 종합 Feedback 카드 ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FEEDBACK"
                        android:textSize="11sp"
                        android:textColor="#AAFFFFFF"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_feedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Generating feedback..."
                        android:textSize="14sp"
                        android:textColor="#EEFFFFFF"
                        android:lineSpacingMultiplier="1.5"
                        android:layout_marginTop="10dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ── CLOSE 버튼 ── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="36dp"
        android:text="CLOSE"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:letterSpacing="0.15"
        android:backgroundTint="#FFFFFF"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>