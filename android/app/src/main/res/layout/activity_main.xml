<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <!-- 배경 이미지 -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── 배경 dim 오버레이 (가독성 확보) ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── 타이틀 ── -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FluentSpeech"
        android:textSize="42sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.05"
        android:fontFamily="sans-serif-light"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.12"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ── 서브타이틀 ── -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Real-time stuttering detection"
        android:textSize="14sp"
        android:textColor="#BBFFFFFF"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

    <!-- ── 구분선 ── -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:background="#AAFFFFFF"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════
         CARD 1 : Mode Selection
    ══════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_mode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#1AFFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODE"
                android:textSize="11sp"
                android:textColor="#AAFFFFFF"
                android:letterSpacing="0.2"
                android:textStyle="bold" />

            <!-- Real-Time -->
            <CheckBox
                android:id="@+id/checkbox_realtime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Real-Time Feedback"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:buttonTint="#FFFFFF"
                android:layout_marginTop="14dp" />

            <!-- Report Only -->
            <CheckBox
                android:id="@+id/checkbox_report"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Report Only"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:buttonTint="#FFFFFF"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════
         CARD 2 : Sensor Selection
    ══════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_sensor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#1AFFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_mode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SENSOR"
                android:textSize="11sp"
                android:textColor="#AAFFFFFF"
                android:letterSpacing="0.2"
                android:textStyle="bold" />

            <!-- Voice + Camera -->
            <CheckBox
                android:id="@+id/checkbox_voice_camera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Voice + Camera"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:buttonTint="#FFFFFF"
                android:layout_marginTop="14dp" />

            <!-- Voice Only -->
            <CheckBox
                android:id="@+id/checkbox_voice_only"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Voice Only"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:buttonTint="#FFFFFF"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── START 버튼 ── -->
    <Button
        android:id="@+id/btn_start"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="32dp"
        android:text="START"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:letterSpacing="0.15"
        android:backgroundTint="#FFFFFF"
        style="@style/Widget.MaterialComponents.Button"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toBottomOf="@id/card_sensor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── 하단 크레딧 ── -->
    <TextView
        android:id="@+id/tv_credit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="blank"
        android:textSize="11sp"
        android:textColor="#66FFFFFF"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>