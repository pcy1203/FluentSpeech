<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── 배경 이미지 ── -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── dim 오버레이 ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════
         TOP BAR : Title + Timer
    ══════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tv_session_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FluentSpeech"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.05"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="36dp"
        android:layout_marginStart="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── 구분선 ── -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="28dp"
        app:layout_constraintTop_toBottomOf="@id/tv_session_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════
         CAMERA PREVIEW (useCamera=true 일 때만 visible)
    ══════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/camera_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="4:3">

        <!-- CameraX PreviewView -->
        <androidx.camera.view.PreviewView
            android:id="@+id/camera_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 얼굴 유도선 오버레이 -->
        <com.chanyoungpark.fluentspeech.FaceGuideOverlayView
            android:id="@+id/face_guide_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- ══════════════════════════════════════════
         FEEDBACK MESSAGE (fade in/out)
    ══════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_feedback"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="20dp"
        android:alpha="0"
        app:cardBackgroundColor="#1AFFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/camera_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_feedback_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FEEDBACK"
                android:textSize="10sp"
                android:textColor="#AAFFFFFF"
                android:letterSpacing="0.2"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_feedback_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Listening..."
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginTop="6dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════
         TENSION GAUGES
    ══════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_tension"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#1AFFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_feedback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TENSION"
                android:textSize="10sp"
                android:textColor="#AAFFFFFF"
                android:letterSpacing="0.2"
                android:textStyle="bold" />

            <!-- Voice Tension -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Voice"
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF" />

                <ProgressBar
                    android:id="@+id/progress_voice_tension"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:progress="0"
                    android:max="100"
                    android:progressDrawable="@drawable/progress_voice"
                    android:background="@drawable/progress_bg" />

                <TextView
                    android:id="@+id/tv_voice_tension_pct"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Face Tension (카메라 모드에서만 의미 있음) -->
            <LinearLayout
                android:id="@+id/layout_face_tension"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Face"
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF" />

                <ProgressBar
                    android:id="@+id/progress_face_tension"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:progress="0"
                    android:max="100"
                    android:progressDrawable="@drawable/progress_face"
                    android:background="@drawable/progress_bg" />

                <TextView
                    android:id="@+id/tv_face_tension_pct"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════
         BOTTOM : START / END BUTTON
    ══════════════════════════════════════════ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_session"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="36dp"
        android:text="START"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:letterSpacing="0.15"
        android:backgroundTint="#FFFFFF"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── 하단 크레딧 ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="blank"
        android:textSize="11sp"
        android:textColor="#44FFFFFF"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/btn_session"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>